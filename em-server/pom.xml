				<profiles.active>dev</profiles.active>
				<nacos.url>192.168.86.131:8848,192.168.86.133:8848</nacos.url>
			</properties>
			<activation>
				<activeByDefault>true</activeByDefault>
			</activation>
		</profile>
		<profile>
			<id>test</id>
			<properties>
				<profiles.active>test</profiles.active>
